<!DOCTYPE html>
<html>

<head>
    <title>Patient Session Analytics</title>
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        :root {
            --bg: #0f111a;
            --card: #1a1d29;
            --accent: #00f2ff;
            --danger: #ff3366;
            --success: #2ecc71;
            --text-main: #e0e0e0;
            --text-dim: #707585;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-main);
            margin: 0;
            display: flex;
            justify-content: center;
            padding: 40px;
        }

        .report-container {
            width: 100%;
            max-width: 800px;
            background: var(--card);
            padding: 40px;
            border-radius: 28px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .report-header {
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding-bottom: 20px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.03);
            padding: 25px;
            border-radius: 18px;
            text-align: center;
        }

        .stat-label {
            font-size: 0.75rem;
            color: var(--text-dim);
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .stat-value {
            font-size: 2.5rem;
            font-weight: 800;
            margin: 0;
        }

        .info-box {
            background: rgba(255, 255, 255, 0.02);
            padding: 25px;
            border-radius: 18px;
            margin-bottom: 20px;
        }

        .condition-badge {
            display: inline-block;
            padding: 8px 20px;
            border-radius: 30px;
            font-weight: bold;
            font-size: 0.9rem;
        }

        /* Smart Print Button Style */
        .print-btn {
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-dim);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 8px 16px;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.8rem;
            font-weight: 600;
            transition: all 0.2s ease;
        }

        .print-btn:hover {
            background: var(--accent);
            color: #000;
            border-color: var(--accent);
            box-shadow: 0 0 15px rgba(0, 242, 255, 0.2);
        }

        /* CRITICAL: Print Media Query (Saves Ink) */
        @media print {
            body {
                background: white !important;
                color: black !important;
                padding: 0;
            }

            .report-container {
                box-shadow: none !important;
                border: none !important;
                width: 100% !important;
                max-width: 100% !important;
                background: white !important;
            }

            .print-btn {
                display: none !important;
            }

            /* Hide button on the actual paper */
            .stat-card,
            .info-box {
                border: 1px solid #eee !important;
                background: white !important;
            }

            .stat-value,
            #view-title {
                color: black !important;
            }

            .condition-badge {
                border: 1px solid #ccc !important;
                background: white !important;
            }
        }

        #view-time {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 30px;
        }

        /* Footer Styles */
        .main-footer {
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            width: 100%;
        }

        .footer-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .copyright {
            font-size: 0.75rem;
            color: var(--text-dim);
            margin: 0;
        }

        .linkedin-link {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-dim);
            text-decoration: none;
            font-size: 0.75rem;
            font-weight: 500;
            transition: all 0.3s ease;
            padding: 5px 12px;
            border-radius: 6px;
            background: rgba(255, 255, 255, 0.02);
        }

        .linkedin-link:hover {
            color: #0077b5;
            /* LinkedIn's Brand Color */
            background: rgba(0, 119, 181, 0.1);
            transform: translateY(-1px);
        }

        /* Ensure icons render in the footer */
        .linkedin-link i {
            display: inline-block;
        }

        @media (max-width: 600px) {
            .footer-content {
                flex-direction: column;
                text-align: center;
            }
        }



        /* Navigation Styles */
        .smart-nav {
            position: relative;
            top: 0;
            left: 0;
            width: 100%;
            background: rgba(26, 29, 41, 0.8);
            /* Semi-transparent card color */
            backdrop-filter: blur(10px);
            /* Blur effect for "Smart" look */
            z-index: 1000;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            margin-bottom: 20px;
        }

        .nav-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 12px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }   

        .nav-links {
            display: flex;
            align-items: center;
            gap: 25px;
        }

        .nav-item {
            color: var(--text-dim);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: color 0.2s ease;
        }

        .nav-item:hover {
            color: var(--accent);
        }

        /* System Status Pill */
        .system-status {
            background: rgba(0, 242, 255, 0.1);
            color: var(--accent);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 6px;
            letter-spacing: 1px;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            background-color: var(--accent);
            border-radius: 50%;
            box-shadow: 0 0 8px var(--accent);
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0% {
                opacity: 1;
            }

            50% {
                opacity: 0.3;
            }

            100% {
                opacity: 1;
            }
        }

        @media (max-width: 600px) {
            .nav-item span {
                display: none;
            }

            /* Icon only on mobile */
            .brand-name {
                font-size: 1rem;
            }
        }
    </style>


</head>

<body>
    <div class="report-container">
        <%- include('nav.ejs') %>

            <header class="report-header">
                <div>
                    <h1 id="view-title">
                        <%= reportData.title %>
                    </h1>
                    <% if (reportData.datetime.getHours() + 1> 12) { %>

                        <div class="timestamp" id="view-time"><i data-lucide="calendar" size="14"></i>
                            <p>

                                <%= reportData.datetime.getDate() %>/<%= reportData.datetime.getMonth() + 1 %>/<%=
                                            reportData.datetime.getFullYear() %> | <%= reportData.datetime.getHours() +
                                                1 - 12 %>
                                                :
                                                <%= reportData.datetime.getMinutes() +1 %> | PM

                            </p>

                        </div>

                        <% } %>
                </div>
                <button class="print-btn" onclick="window.print()">
                    <i data-lucide="printer" size="16"></i> PRINT REPORT
                </button>
            </header>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-label">Max BPM</div>
                    <p class="stat-value" id="view-max" style="color: var(--danger);">
                        <%= reportData.maxBpm %>
                    </p>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Min BPM</div>
                    <p class="stat-value" id="view-min" style="color: var(--accent);">
                        <%= reportData.minBpm %>

                    </p>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Avg BPM</div>
                    <p class="stat-value" id="view-avg" style="color: var(--success);">
                        <%= reportData.avgBpm %>
                    </p>
                </div>
            </div>

            <div class="info-box">
                <div class="stat-label">General Condition</div>
                <div id="view-condition" class="condition-badge">
                    <%= reportData.condition %>
                </div>
            </div>

            <div class="info-box">
                <div class="stat-label">Doctor's Notes</div>
                <p id="view-notes" style="line-height: 1.6;">
                    <%= reportData.notes %>
                </p>
            </div>

            <%- include('footer.ejs') %>

    </div>

    <script>
        lucide.createIcons();
    </script>
</body>

</html>